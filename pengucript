-- ⚠ SYSTEM ERROR LOOP
----------------------------------------------------
task.spawn(function()
	local msgs = {
		"FIREWALL BREACH",
		"UNAUTHORIZED ACCESS",
		"TRACKING IP",
		"DEVICE IDENTIFIED",
		"SYSTEM CORRUPTION",
		"DATA LEAK DETECTED"
	}

	while true do
		local m = msgs[math.random(1,#msgs)]

		pcall(function()
			StarterGui:SetCore("SendNotification", {
				Title = "SYSTEM ERROR",
				Text = m,
				Duration = 0.2
			})
		end)

		log.Text = log.Text .. "\n[" .. m .. "]"
		task.wait(math.random(2,5)*0.1)
	end
end)

