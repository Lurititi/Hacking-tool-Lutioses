----------------------------------------------------
-- 🧱 UI
----------------------------------------------------
local gui = Instance.new("ScreenGui")
gui.Parent = player:WaitForChild("PlayerGui")

local frame = Instance.new("Frame")
frame.Size = UDim2.new(0.6,0,0.5,0)
frame.Position = UDim2.new(0.2,0,0.25,0)
frame.BackgroundColor3 = Color3.fromRGB(18,18,18)
frame.BorderSizePixel = 0
frame.Parent = gui

local log = Instance.new("TextLabel")
log.Size = UDim2.new(1,0,1,0)
log.BackgroundTransparency = 1
log.TextColor3 = Color3.fromRGB(235,235,235)
log.Font = Enum.Font.Code
log.TextSize = 18
log.TextXAlignment = Enum.TextXAlignment.Left
log.TextYAlignment = Enum.TextYAlignment.Top
log.Text = ""
log.Parent = frame

local function typeLine(text)
	for i = 1, #text do
		log.Text = log.Text .. text:sub(i,i)
		task.wait(0.015)
	end
	log.Text = log.Text .. "\n"
	task.wait(0.2)
end

local device = UserInputService.TouchEnabled and "MOBILE" or "PC"

----------------------------------------------------
-- 🚀 MAIN LOG
----------------------------------------------------
typeLine("SYSTEM / 시스템: 보안 검사 시작")
typeLine("USER / 사용자: " .. player.Name)
typeLine("DEVICE / 기기: " .. device)
typeLine("ANALYZING SESSION...")
typeLine("WARNING: TRACKING ACTIVE")

